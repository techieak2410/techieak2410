//26. Remove Duplicates from Sorted Array----leetcode problem



class Solution {
    public int removeDuplicates(int[] nums) {
        int increment=0;
        int store=-101;
        for(int j=0;j<nums.length;j++){
            if(nums[j]!=store){
                store=nums[j];
                nums[increment++]=nums[j];
            }
            
        }
        return increment;
        
    }
} 
